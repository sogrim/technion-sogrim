# Sogrim Back Office — environment template. Copy to `.env.local` and fill in.
#
# IMPORTANT: every VITE_* variable is inlined into the client bundle at build
# time, so it is PUBLIC. Never put a secret here. Access control is enforced
# server-side (see README "Security"); nothing here grants access on its own.

# Google OAuth client id — the SAME public client id the main sogrim app uses.
# (A client id is not a secret. The OAuth client *secret*, if any, lives only
#  on the server and must never appear in this app.)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Backend API base URL. Leave as "/api" to use the Vite dev proxy, which
# forwards to the local server at http://localhost:5545 (see vite.config.ts).
VITE_API_URL=/api

# Set to "true" to render the UI from built-in mock fixtures with NO backend
# and NO login — local UI development only. Real access is always enforced
# server-side regardless of this flag.
VITE_USE_MOCKS=false
